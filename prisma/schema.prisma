generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  displayName  String
  whatsappNumber String?
  role         String
  isActive     Boolean  @default(true)
  darkMode     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions           Session[]
  requestedRequests  WorkRequest[]      @relation("RequestRequester")
  requestDrafts      RequestDraft[]     @relation("DraftRequester")
  claimedRequests    WorkRequest[]      @relation("RequestCreator")
  timeLogs           WorkTimeLog[]      @relation("TimeLogCreator")
  submissions        WorkSubmission[]   @relation("SubmissionCreator")
  notes              TaskNote[]         @relation("TaskNoteUser")
  reviewLogs         ReviewLog[]        @relation("ReviewReviewer")
  createdBankItems   ContentBank[]      @relation("BankCreator")
  requestedBankItems ContentBank[]      @relation("BankRequester")
  createdMaterials   MaterialReference[] @relation("MaterialCreator")
  requestedMaterials MaterialReference[] @relation("MaterialRequester")
  feedbacks          AssetFeedback[]    @relation("FeedbackReviewer")
  statusLogs         CreatorStatusLog[]
}

model RequestDraft {
  id                  String   @id @default(cuid())
  requestType         String
  requesterId         String
  productName         String?
  postPlatform        String?
  style               String?
  angle               String?
  hook                String?
  domainLpUrl         String?
  referenceLinks      String?
  rawOrReferenceLinks String?
  videoAmount         Int      @default(0)
  imageAmount         Int      @default(0)
  useFrame            String?
  deadlineAt          DateTime?
  additionalNotes     String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  requester User @relation("DraftRequester", fields: [requesterId], references: [id], onDelete: Cascade)

  @@index([requestType])
  @@index([requesterId])
  @@index([updatedAt])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Product {
  id                String   @id @default(cuid())
  name              String
  normalizedName    String   @unique
  category          String?
  niche             String?
  description       String?
  notes             String?
  mainLpUrl         String?
  driveReferenceUrl String?
  tags              String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  requests  WorkRequest[]
  bankItems ContentBank[]
  materials MaterialReference[]
}

model WorkRequest {
  id                  String    @id @default(cuid())
  requestType         String
  productName         String
  productKey          String
  productId           String?
  requesterId         String
  creatorId           String?
  title               String
  postPlatform        String
  style               String?
  angle               String?
  hook                String?
  domainLpUrl         String?
  referenceLinks      String?
  rawOrReferenceLinks String?
  videoAmount         Int       @default(0)
  imageAmount         Int       @default(0)
  useFrame            String?
  deadlineAt          DateTime
  additionalNotes     String?
  status              String    @default("BELUM")
  startedAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  product     Product?         @relation(fields: [productId], references: [id])
  requester   User             @relation("RequestRequester", fields: [requesterId], references: [id])
  creator     User?            @relation("RequestCreator", fields: [creatorId], references: [id])
  timeLogs    WorkTimeLog[]
  submissions WorkSubmission[]
  notes       TaskNote[]
  reviewLogs  ReviewLog[]
  bankItems   ContentBank[]
  materials   MaterialReference[]

  @@index([requestType])
  @@index([status])
  @@index([deadlineAt])
  @@index([productKey])
  @@index([requesterId])
  @@index([creatorId])
}

model WorkTimeLog {
  id              String    @id @default(cuid())
  requestId       String
  creatorId       String
  logType         String
  startedAt       DateTime
  endedAt         DateTime?
  durationSeconds Int?
  note            String?
  createdAt       DateTime  @default(now())

  request WorkRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  creator User        @relation("TimeLogCreator", fields: [creatorId], references: [id])

  @@index([requestId])
  @@index([creatorId])
  @@index([endedAt])
}

model WorkSubmission {
  id                   String   @id @default(cuid())
  requestId            String
  creatorId            String
  submissionType       String
  mainLink             String
  additionalLinks      String?
  submittedVideoAmount Int      @default(0)
  submittedImageAmount Int      @default(0)
  note                 String?
  version              Int      @default(1)
  createdAt            DateTime @default(now())

  request WorkRequest       @relation(fields: [requestId], references: [id], onDelete: Cascade)
  creator User              @relation("SubmissionCreator", fields: [creatorId], references: [id])
  assets  SubmissionAsset[]
  materials MaterialReference[]

  @@index([requestId])
  @@index([creatorId])
}

model SubmissionAsset {
  id           String   @id @default(cuid())
  submissionId String
  requestId    String
  assetKind    String
  title        String
  link         String
  note         String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  submission WorkSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([requestId])
  @@index([assetKind])
}

model TaskNote {
  id        String   @id @default(cuid())
  requestId String
  userId    String
  noteType  String   @default("GENERAL")
  note      String
  createdAt DateTime @default(now())

  request WorkRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user    User        @relation("TaskNoteUser", fields: [userId], references: [id])

  @@index([requestId])
  @@index([userId])
}

model ReviewLog {
  id         String   @id @default(cuid())
  requestId  String
  reviewerId String
  decision   String
  reviewNote String?
  createdAt  DateTime @default(now())

  request  WorkRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  reviewer User        @relation("ReviewReviewer", fields: [reviewerId], references: [id])

  @@index([requestId])
  @@index([reviewerId])
}

model ContentBank {
  id                   String   @id @default(cuid())
  requestId            String
  productId            String?
  productName          String
  productKey           String
  title                String
  assetType            String
  assetKind            String
  platform             String
  style                String?
  angle                String?
  hook                 String?
  requestedVideoAmount Int      @default(0)
  requestedImageAmount Int      @default(0)
  submittedVideoAmount Int      @default(0)
  submittedImageAmount Int      @default(0)
  mainLink             String
  additionalLinks      String?
  creatorId            String?
  requesterId          String
  testStatus           String   @default("READY_TEST")
  scoreTotal           Int?
  feedbackCount        Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  request   WorkRequest     @relation(fields: [requestId], references: [id], onDelete: Cascade)
  product   Product?        @relation(fields: [productId], references: [id])
  creator   User?           @relation("BankCreator", fields: [creatorId], references: [id])
  requester User            @relation("BankRequester", fields: [requesterId], references: [id])
  feedbacks AssetFeedback[]

  @@index([requestId])
  @@index([productKey])
  @@index([assetType])
  @@index([assetKind])
  @@index([testStatus])
  @@index([creatorId])
}

model MaterialReference {
  id           String   @id @default(cuid())
  materialType String
  sourceType   String
  productId    String?
  productName  String
  productKey   String
  requestId    String?
  submissionId String?
  title        String
  url          String
  platform     String?
  note         String?
  requesterId  String?
  creatorId    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  product    Product?        @relation(fields: [productId], references: [id])
  request    WorkRequest?    @relation(fields: [requestId], references: [id], onDelete: Cascade)
  submission WorkSubmission? @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  requester  User?           @relation("MaterialRequester", fields: [requesterId], references: [id])
  creator    User?           @relation("MaterialCreator", fields: [creatorId], references: [id])

  @@index([materialType])
  @@index([sourceType])
  @@index([productKey])
  @@index([requestId])
  @@index([submissionId])
  @@index([requesterId])
  @@index([creatorId])
}

model AssetFeedback {
  id                   String    @id @default(cuid())
  contentBankId        String
  reviewerId           String
  testStatus           String?
  testedPlatform       String?
  testDate             DateTime?
  testResult           String?
  budgetSpent          Float?
  spend                Float?
  ctr                  Float?
  cpc                  Float?
  cpm                  Float?
  cpl                  Float?
  roas                 Float?
  leads                Int?
  sales                Int?
  revenue              Float?
  profit               Float?
  conversionRate       Float?
  score1               Int?
  score2               Int?
  score3               Int?
  score4               Int?
  score5               Int?
  totalScore           Int?
  feedbackNote         String?
  suggestionForCreator String?
  createdAt            DateTime  @default(now())

  contentBank ContentBank @relation(fields: [contentBankId], references: [id], onDelete: Cascade)
  reviewer    User        @relation("FeedbackReviewer", fields: [reviewerId], references: [id])

  @@index([contentBankId])
  @@index([reviewerId])
}

model CreatorStatusLog {
  id              String    @id @default(cuid())
  userId          String
  status          String
  reason          String?
  note            String?
  startedAt       DateTime
  expectedUntil   DateTime?
  endedAt         DateTime?
  durationSeconds Int?
  createdAt       DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([endedAt])
}

model AppSetting {
  key       String   @id
  value     String?
  updatedAt DateTime @updatedAt
}
